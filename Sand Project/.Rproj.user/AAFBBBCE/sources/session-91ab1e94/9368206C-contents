Plot the points:
```{r}


leaflet(data) %>%
  addTiles() %>% 
  #addProviderTiles(providers$CartoDB.Positron)%>% 
  addProviderTiles(providers$Esri.WorldImagery)%>% 
  addCircleMarkers(data = data,
             lng = ~longitude, 
             lat =  ~latitude, 
             radius = 5,
             color = "#FFAC1C",
             popup = ~paste("<strong>Start Date:</strong> ", start_date_of_the_incident, "<br>",
                            "<strong>Harms Reported:</strong> ", what_kind_of_impact_or_harm_are_you_reporting_please_check_all_that_apply, "<br>",
